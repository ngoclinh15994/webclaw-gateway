{
  "manifest_version": 3,
  "name": "WebClaw Cookie Sync",
  "version": "1.0",
  "description": "Extract cookies from active tab and sync to WebClaw Hybrid Engine.",
  "permissions": ["cookies", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "WebClaw Cookie Sync",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "cookies_16.png",
    "48": "cookies_48.png",
    "128": "cookies_128.png"
  }
}
